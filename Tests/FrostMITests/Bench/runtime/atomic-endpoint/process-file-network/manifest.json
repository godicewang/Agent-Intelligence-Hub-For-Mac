{
  "id": "runtime-atomic-endpoint-process-file-network",
  "baseline": "Atomic Red Team + osquery/Sigma-style endpoint telemetry",
  "reference": "https://github.com/redcanaryco/atomic-red-team",
  "license": "Atomic Red Team MIT; osquery Apache-2.0; Sigma Detection Rule License. This fixture is FrostMI-authored and contains no copied rule content.",
  "focus": "Endpoint runtime visibility for process identity, workspace file changes, outbound model endpoint evidence, and permission status.",
  "input": {
    "events": "events.jsonl"
  },
  "expected": {
    "agents": [
      {
        "normalizedName": "cursor",
        "minConfidence": 80,
        "runtimeStatus": "running"
      }
    ],
    "absentAgents": [
      "cline-roocode",
      "runtime-cursor-6101"
    ],
    "allowExtraAgents": false,
    "runtimeProcessesMinCount": 1,
    "evidenceMinCount": 3,
    "runtimeEventsMinCount": 4,
    "sessionGraphEdgesMinCount": 2,
    "exactCounts": {
      "agents": 1,
      "runtimeProcesses": 1,
      "evidence": 3,
      "contextFiles": 1,
      "memoryAssets": 0,
      "permissionStates": 1
    },
    "runtimeProcesses": [
      {
        "agent": "cursor",
        "processName": "Cursor",
        "minScore": 80,
        "providers": [
          "OpenAI"
        ],
        "workspaceSuffix": "project"
      }
    ],
    "contextFiles": [
      "project/.cursor/rules/runtime.mdc"
    ],
    "permissionStates": [
      {
        "capability": "fileSystemEvents",
        "status": "available"
      }
    ],
    "requiredEventKinds": [
      "processObservation",
      "fileSystemChange",
      "permissionState"
    ],
    "requiredEvidenceSummaries": [
      "Network destination observed"
    ],
    "requiredEvidence": [
      {
        "agent": "cursor",
        "type": "process",
        "source": "cursor",
        "processId": 6101,
        "summaryContains": "Known process fingerprint matched"
      },
      {
        "agent": "cursor",
        "type": "contextFile",
        "processId": 6101,
        "pathSuffix": "project/.cursor/rules/runtime.mdc"
      },
      {
        "agent": "cursor",
        "type": "behavior",
        "processId": 6101,
        "summaryContains": "Network destination observed"
      }
    ],
    "requireLinkedEvidence": true,
    "knownGaps": [
      {
        "capability": "endpoint_security_auth_events",
        "reason": "Development builds record permission state but do not require Endpoint Security entitlement-backed auth events."
      },
      {
        "capability": "network_extension_flow_detail",
        "reason": "The runtime bench records destination evidence without requiring Network Extension capture."
      }
    ]
  }
}
